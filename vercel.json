{
  "framework": "vite",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/case-studies/:slug([a-z0-9][a-z0-9-]*)", "destination": "/api/case-study/:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
