# PUBLIC — these are inlined into the client bundle by Vite (VITE_ prefix).
# The anon key is safe to expose ONLY because Row Level Security restricts it.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SECRET — server-side only. NEVER prefix a secret with VITE_ (it would be
# bundled into the public client JS). Used only by scripts/upload-case-studies.mjs
# to write to Storage. Find it in Supabase -> Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
