# ============================================================================
# PUBLIC keys — inlined into the client JS bundle by Vite (VITE_ prefix) and
# therefore visible to anyone. Only keys that are SAFE to expose go here.
# ============================================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Use the PUBLISHABLE key (sb_publishable_...) or the legacy "anon" key.
# These map to the `anon` role and RESPECT Row Level Security.
# NEVER put a SECRET key (sb_secret_...) or the service_role JWT here — those
# bypass RLS and would hand full read/write access to every site visitor.
VITE_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key-here

# ============================================================================
# SECRET — server-side only. NEVER prefix with VITE_ (it would be bundled into
# the public client JS). Used only by scripts/upload-case-studies.mjs to write
# to Storage. Use the service_role JWT or a secret key (sb_secret_...).
# Find it in Supabase -> Settings -> API Keys.
# ============================================================================
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
